# Segurança
JWT_SECRET=seu_jwt_secret_aqui_minimo_32_chars

# Banco de dados (Railway MySQL plugin — copiar do painel Railway → MySQL → Connect)
DB_HOST=containers-us-west-xxx.railway.app
DB_USER=root
DB_PASSWORD=
DB_NAME=railway
DB_PORT=3306

# API de IA
GEMINI_API_KEY=sua_chave_aqui

# CORS — URL pública da aplicação (Railway gera automaticamente)
CORS_ORIGIN=https://seu-app.railway.app

# Ambiente
NODE_ENV=production
PORT=3000
